{
  "name": "rest-express",
  "version": "1.0.0",
  "license": "MIT",
  "scripts": {
    "dev": "tsx watch server/index.ts",
    "build": "tsx script/build.ts",
    "start": "NODE_ENV=production node dist/index.cjs",
    "check": "tsc",
    "test": "vitest run",
    "test:unit": "vitest run tests/unit",
    "test:integration": "vitest run tests/integration",
    "test:coverage": "vitest run --coverage",
    "test:e2e:smoke": "playwright test --config=playwright.config.ts --grep @smoke",
    "ci": "npm run check && npm run test:unit && npm run test:integration && npm run test:e2e:smoke",
    "db:migrate": "tsx server/migrations/runner.ts",
    "db:backfill": "tsx server/scripts/backfill.ts",
    "whatsapp:simple": "node scripts/whatsapp-simple.cjs",
    "db:push": "drizzle-kit push"
  },
  "dependencies": {
    "connect-pg-simple": "^10.0.0",
    "cors": "^2.8.6",
    "date-fns": "^3.6.0",
    "dotenv": "^17.2.3",
    "drizzle-orm": "^0.39.3",
    "drizzle-zod": "^0.7.0",
    "express": "^5.0.1",
    "express-session": "^1.19.0",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "memoizee": "^0.4.17",
    "memorystore": "^1.6.7",
    "mongoose": "^9.3.1",
    "nodemailer": "^9.0.0",
    "openid-client": "^6.8.1",
    "passport": "^0.7.0",
    "passport-local": "^1.0.0",
    "pg": "^8.21.0",
    "qrcode": "^1.5.4",
    "qrcode-terminal": "^0.12.0",
    "socket.io": "^4.8.3",
    "whatsapp-web.js": "^1.34.4",
    "ws": "^8.18.0",
    "zod": "^3.24.2",
    "zod-validation-error": "^3.4.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/pg": "^8.20.0",
    "drizzle-kit": "^0.31.8",
    "esbuild": "^0.25.0",
    "mongodb-memory-server": "^11.0.1",
    "supertest": "^7.2.2",
    "tsx": "^4.20.5",
    "typescript": "5.6.3",
    "vitest": "^4.1.0"
  },
  "overrides": {
    "drizzle-kit": {
      "@esbuild-kit/esm-loader": "npm:tsx@^4.20.4"
    }
  },
  "optionalDependencies": {
    "bufferutil": "^4.0.8"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "bufferutil",
      "es5-ext",
      "esbuild",
      "mongodb-memory-server",
      "puppeteer"
    ]
  },
  "onlyBuiltDependencies": [
    "bufferutil",
    "es5-ext",
    "esbuild",
    "mongodb-memory-server",
    "puppeteer"
  ]
}