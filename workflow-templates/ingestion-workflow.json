                        "type": "main",
                        "index": 0
                    }
                ]
            ]
        },
        "Init Full Sync State": {
            "main": [
                [
                    {
                        "node": "Fetch Products Page",
                        "type": "main",
                        "index": 0
                    }
                ]
            ]
        },
        "Route by Topic": {
            "main": [
                [
                    {
                        "node": "Delete from Neon",
                        "type": "main",
                        "index": 0
                    }
                ],
                [
                    {
                        "node": "Clean and Chunk",
                        "type": "main",
                        "index": 0
                    }
                ]
            ]
        },
        "Fetch Products Page": {
            "main": [
                [
                    {
                        "node": "Parse Pagination",
                        "type": "main",
                        "index": 0
                    }
                ]
            ]
        },
        "Parse Pagination": {
            "main": [
                [
                    {
                        "node": "Split Products",
                        "type": "main",
                        "index": 0
                    },
                    {
                        "node": "Check Next",
                        "type": "main",
                        "index": 0
                    }
                ]
            ]
        },
        "Split Products": {
            "main": [
                [
                    {
                        "node": "Filter Active",
                        "type": "main",
                        "index": 0
                    }
                ]
            ]
        },
        "Filter Active": {
            "main": [
                [
                    {
                        "node": "Check Neon Existing",
